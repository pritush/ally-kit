{
  "name": "@preepo/allykit",
  "version": "1.3.0",
  "description": "AllyKit — a lightweight, zero-dependency accessibility toolkit for any webpage. Text size, contrast modes, dyslexia font, screen reader, ADHD focus mode, and more.",
  "main": "ally-kit.js",
  "module": "ally-kit.js",
  "browser": "ally-kit.js",
  "types": "ally-kit.d.ts",
  "exports": {
    ".": {
      "types": "./ally-kit.d.ts",
      "import": "./ally-kit.js",
      "require": "./ally-kit.js",
      "default": "./ally-kit.js"
    }
  },
  "files": [
    "ally-kit.js",
    "ally-kit-min.js",
    "ally-kit.d.ts",
    "open-dyslexic.woff",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 0",
    "build": "terser ally-kit.js -o ally-kit-min.js -m -c",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "wcag2.2",
    "allykit",
    "screen-reader",
    "high-contrast",
    "dyslexia",
    "widget",
    "zero-dependency",
    "typescript"
  ],
  "author": "Pritush M.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pritush/ally-kit.git"
  },
  "bugs": {
    "url": "https://github.com/pritush/ally-kit/issues"
  },
  "homepage": "https://github.com/pritush/ally-kit#readme",
  "sideEffects": false,
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "terser": "^5.49.0"
  }
}
